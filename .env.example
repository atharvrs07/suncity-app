# Server
PORT=4000
JWT_SECRET=change-me-to-a-long-random-string

# Persistent data directory (SQLite DB + uploaded photos live here).
# On your host, point this at a directory that survives redeploys.
# DATA_DIR=/var/data/suncity

# UPI payment details shown in the payment QR
SOCIETY_UPI_VPA=society@upi
SOCIETY_UPI_PAYEE_NAME=My Suncity Vistaar

# Fallback admin — created/promoted automatically whenever zero approved
# admins exist, so the approval chain can never get stuck.
ADMIN_SEED_NAME=Society Admin
ADMIN_SEED_PHONE=9999999999
ADMIN_SEED_PASSWORD=admin123
