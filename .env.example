# Server
PORT=4000
JWT_SECRET=change-me-to-a-long-random-string

# Persistent data directory (SQLite DB + uploaded photos live here).
# On your host, point this at a directory that survives redeploys.
# DATA_DIR=/var/data/suncity

# UPI payment details shown in the payment QR
SOCIETY_UPI_VPA=society@upi
SOCIETY_UPI_PAYEE_NAME=My Suncity Vistaar

# Fallback admin — created/promoted automatically whenever zero approved
# admins exist, so the approval chain can never get stuck.
ADMIN_SEED_NAME=Society Admin
ADMIN_SEED_PHONE=9999999999
ADMIN_SEED_PASSWORD=admin123

# Transactional emails (Gmail SMTP): password resets, resident signup OTP codes,
# and new-resident notifications to admins.
# GMAIL_APP_PASSWORD is a 16-character Google "App Password" (Google account →
# Security → 2-Step Verification → App passwords) — NOT the account password.
# Leave it empty in dev: emails (incl. OTP codes) are then logged to the server
# console instead of sent, so the flows stay testable.
GMAIL_USER=suncityvistaar2000@gmail.com
GMAIL_APP_PASSWORD=

# Public base URL used inside emailed reset links AND as the OAuth redirect
# host. Defaults to http://localhost:PORT — set this on your deployed host.
# For OAuth to work end to end this MUST be the exact public origin that serves
# the app (the provider redirect URIs and the post-login redirect are built
# from it), so run OAuth against a build (`npm run build && npm start`) rather
# than the split dev origin.
# APP_BASE_URL=https://your-domain.example

# ---------------------------------------------------------------------------
# OAuth / social sign-in (Google, Microsoft, Apple)
# ---------------------------------------------------------------------------
# All optional: leave a provider's variables blank and its sign-in button
# simply doesn't appear (the endpoints return 404). Fill them in after
# registering the app in each provider's console — see OAUTH_SETUP.md for the
# exact steps, redirect URIs, and scopes to configure on their side.
#
# The single redirect URI to register for each provider is:
#   <APP_BASE_URL>/api/auth/oauth/<provider>/callback
# e.g. https://your-domain.example/api/auth/oauth/google/callback

# Google (Google Cloud Console → APIs & Services → Credentials → OAuth client ID, type "Web application")
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Microsoft / Azure Entra ID (App registration → Certificates & secrets + Authentication → Web redirect URI)
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
# 'common' = any Microsoft account; or a specific tenant (directory) GUID to restrict to your org.
MICROSOFT_OAUTH_TENANT=common

# Apple (Apple Developer → Certificates, IDs & Profiles → a Services ID + a Sign in with Apple key .p8)
# APPLE_OAUTH_SERVICES_ID is the Services identifier (acts as the OAuth client_id).
# APPLE_OAUTH_PRIVATE_KEY is the contents of the downloaded .p8 file. Keep the
# BEGIN/END lines; either paste real newlines or escape them as \n on one line.
# NOTE: Apple does NOT allow http/localhost redirect URIs — it needs a public
# HTTPS domain, so Apple sign-in can only be tested on a deployed HTTPS host.
APPLE_OAUTH_SERVICES_ID=
APPLE_OAUTH_TEAM_ID=
APPLE_OAUTH_KEY_ID=
APPLE_OAUTH_PRIVATE_KEY=
